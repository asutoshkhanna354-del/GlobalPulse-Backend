# ============================================================
# GlobalPulse Intelligence — Environment Variables
# Copy this file to .env and fill in your actual values
# Set these on Render (backend) dashboard under Environment
# ============================================================

# ── Required ─────────────────────────────────────────────────

# PostgreSQL connection string (Render provides this automatically
# when you create a PostgreSQL database — just copy from the DB dashboard)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Finnhub API key — free tier at https://finnhub.io/register
# Used for: US stocks, forex, crypto WebSocket streaming
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data API key — free tier at https://twelvedata.com/register
# Used for: Indian NSE/BSE WebSocket streaming (backup feed)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# OpenAI API key — https://platform.openai.com/api-keys
# Used for: Nifty AI analysis, BTC analysis, USD signal, chart signal summaries
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ── Push Notifications (optional — skip if you don't need them) ──

# Generate VAPID keys by running:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_CONTACT_EMAIL=admin@yourdomain.com

# ── Server config (set automatically by Render) ──────────────
PORT=8080
NODE_ENV=production

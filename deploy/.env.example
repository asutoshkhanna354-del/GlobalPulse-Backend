# ──────────────────────────────────────────────────────────────────────────────
# GlobalPulse Intelligence — Environment Variables
# Copy this file to .env and fill in your values before deploying.
# ──────────────────────────────────────────────────────────────────────────────

# ── BACKEND (Render) ──────────────────────────────────────────────────────────

# PostgreSQL — auto-set by Render Blueprint when you link the database service
DATABASE_URL=postgresql://user:password@host:5432/globalpulse

# Finnhub — US stocks, forex, indices (free tier: 60 req/min)
# Get your key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Twelve Data — Indian markets (NSE/BSE) and global equities backup
# Get your key at https://twelvedata.com/register
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# OpenAI — AI signal analysis (optional; falls back to rule-based if not set)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Web Push Notifications (optional — skip if you don't need push alerts)
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@yourdomain.com

# Server
PORT=10000
NODE_ENV=production
LOG_LEVEL=info

# ── FRONTEND (Netlify) ────────────────────────────────────────────────────────

# Your Render backend URL — no trailing slash
# Example: https://globalpulse-api.onrender.com
VITE_API_URL=https://your-render-service.onrender.com
